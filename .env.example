# Copy this file to ".env" and adjust as needed:  cp .env.example .env
# The compose files load ".env" automatically (both as ${VAR} substitution and
# via an optional `env_file:`), so it's the single place to configure the stack.
#
# Every value here has a built-in default in the compose files, so you only need
# to set the ones you want to change. The defaults shown match those defaults.
# In production (docker-compose.prod.yml, ENV=production) SECRET_KEY,
# POSTGRES_PASSWORD and ADMIN_PASSWORD are REQUIRED — the stack won't start
# without them.

# --- PostgreSQL ---
POSTGRES_USER=statements
POSTGRES_PASSWORD=statements
POSTGRES_DB=statements
# Postgres image tag (any tag from the official `postgres` image).
POSTGRES_VERSION=16-alpine
# Host interface + port the database is published on (dev stack only).
# DB_HOST=127.0.0.1 keeps it local; use 0.0.0.0 to expose on the network.
DB_HOST=127.0.0.1
DB_PORT=5432

# --- Backend ---
# "development" (default) auto-creates tables and tolerates a missing SECRET_KEY
# by generating an ephemeral one. Set to "production" for real deployments — the
# backend then REFUSES to start without a strong SECRET_KEY and an ADMIN_PASSWORD.
ENV=development

# Signs session tokens. REQUIRED in production: a random string of >=32 chars,
# e.g. `openssl rand -hex 32`. Leave blank in development for an ephemeral key.
SECRET_KEY=

# The single admin account, created on first boot if the database has no users.
# Changing these later has no effect once the account exists — change the
# password from the Settings screen instead.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# --- Documents folder (the headline feature) ---
# Host folder mapped into the backend at /data/documents. Uploaded files are
# filed here as <folder>/<YYYY>/<MM>/<file>. Point this at wherever you keep
# your bookkeeping (e.g. /mnt/nas/accounting or C:/Users/you/Documents/Books).
DOCUMENTS_DIR_HOST=./documents
# Per-file upload size cap in MB (also bounded by nginx; keep them in sync).
MAX_UPLOAD_MB=25

# --- OCR (reading scanned, image-only invoices) ---
# Tesseract OCR runs as a fallback when an uploaded PDF has no text layer, or
# when you upload a photo/scan. Set OCR_ENABLED=0 to disable. OCR_LANG must match
# the language packs installed in the backend image (default: Slovak + English).
OCR_ENABLED=1
OCR_LANG=slk+eng

# --- Ports ---
# Host port for the API (interactive docs at http://localhost:<API_PORT>/docs).
API_PORT=8000
# Host port the web app is served on -> open http://localhost:<APP_PORT>
APP_PORT=3000

# --- Images & runtime ---
# Override to pull/push different image names or tags (e.g. a pinned version).
BACKEND_IMAGE=slamkalukas/statements-backend:latest
FRONTEND_IMAGE=slamkalukas/statements-frontend:latest
# Container restart policy: no | on-failure | always | unless-stopped
RESTART_POLICY=unless-stopped
